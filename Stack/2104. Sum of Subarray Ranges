class Solution {
    public long subArrayRanges(int[] nums) {
        int n =nums.length;
        long totalGreater=sumSubarrayMaxi(nums) , totalSmaller=sumSubarrayMins(nums);
        return totalGreater - totalSmaller;
    }
    private long sumSubarrayMaxi(int[] arr){
        Stack<Integer> st = new Stack<>();
        long sumOfMaxi=0;
        for(int i=0;i<=arr.length;i++){
            while(!st.isEmpty() && (i==arr.length || arr[st.peek()] <= arr[i])){
                int mid=st.pop();
                long leftBoundary = st.empty() ? -1 : st.peek();
                long rightBoundary = i;

                long count = (mid- leftBoundary) * (rightBoundary - mid);
                sumOfMaxi += (count * arr[mid]);
            }
            st.push(i);
        }
        return sumOfMaxi;
    }
    public long sumSubarrayMins(int[] arr) {
        Stack<Integer> st = new Stack<>();
        long sumOfMinimums = 0;

        for (int i = 0; i <= arr.length; i++) {
            while (!st.empty() && (i == arr.length || arr[st.peek()] >= arr[i])) {
                int mid = st.pop();
                long leftBoundary = st.empty() ? -1 : st.peek();
                long rightBoundary = i;

                long count = (mid - leftBoundary) * (rightBoundary - mid);

                sumOfMinimums += (count * arr[mid]);
            }
            st.push(i);
        }

        return sumOfMinimums;
    }
    
}
